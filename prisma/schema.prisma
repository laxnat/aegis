// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Folder {
  id        String     @id @default(cuid())
  name      String     @default("New Folder")
  userId    String
  parentId  String?
  pinned    Boolean    @default(false)
  parent    Folder?    @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]   @relation("FolderChildren")
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
  @@index([parentId])
}

model Document {
  id        String          @id @default(cuid())
  title     String          @default("Untitled")
  userId    String
  folderId  String?
  pinned    Boolean         @default(false)
  status    String?
  folder    Folder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  blocks    Block[]
  shares    DocumentShare[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
  @@index([folderId])
}

model DocumentShare {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ownerUserId String
  sharedEmail String
  permission  String   @default("view")
  createdAt   DateTime @default(now())

  @@unique([documentId, sharedEmail])
  @@index([documentId])
  @@index([sharedEmail])
}

model Block {
  id         String   @id @default(cuid())
  type       String   // "text", "heading1", "heading2", "bulletList", etc.
  content    String   @default("")
  order      Int      // Position in the document
  
  // Document relationship
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  // Nesting relationship (self-referential)
  parentId   String?  // null = top-level block
  parent     Block?   @relation("BlockChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children   Block[]  @relation("BlockChildren")
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([documentId, order]) // Fast queries for ordered blocks
  @@index([parentId])
}